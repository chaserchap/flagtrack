# ── FlagTrack environment config ──────────────────────────────────────────────
# Copy to .env and fill in values before running docker compose up

# Postgres
POSTGRES_DB=flagtrack
POSTGRES_USER=flagtrack
POSTGRES_PASSWORD=changeme_use_a_strong_password

# App port (what Tailscale/host exposes)
# Leave as 80 unless you have something else on port 80
APP_PORT=80
